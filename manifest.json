{
	"name": "snoozify",
	"description": "Snooze tabs to re-open them on a specific day. Clean, simple, no account required.",
	"version": "1.0.0",
	"homepage_url": "https://github.com/pekka-poukamo/snoozify",
	"icons": {
		"16": "/assets/icon-16.png",
		"32": "/assets/icon-32.png",
		"48": "/assets/icon-48.png",
		"128": "/assets/icon-128.png"
	},
	"manifest_version": 3,
	"action": {
		"default_popup": "/pages/popup.html"
	},
	"background": {
		"service_worker": "/scripts/worker.js",
		"type": "module"
	},
	"permissions": [
		"storage",
		"tabs",
		"alarms",
		"notifications"
	]
}